                                    <td class="px-4 py-2 text-zinc-500 dark:text-zinc-400 capitalize hidden sm:table-cell">{{ str_replace('_', ' ', $login->role) }}</td>
                                    <td class="px-4 py-2 text-zinc-500 dark:text-zinc-400 whitespace-nowrap">{{ $login->last_login_at->diffForHumans() }}</td>
                                    <td class="px-4 py-2 text-zinc-500 dark:text-zinc-400 font-mono text-xs hidden md:table-cell">{{ $login->last_login_ip ?? '—' }}</td>
                                </tr>
                            @endforeach
                        </tbody>
                    </table>
